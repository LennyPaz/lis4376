# https://ipython.readthedocs.io/en/stable/interactive/magics.html

# Magic Commands:
# Special commands that help with running and analyzing data in Jupyter notebooks.
# Single % for one line of code, or double %% for several lines of code.





%lsmagic


# example line magic
%ls





# example run file
%run hello.py





# %load hello.py
# Note: File was loaded into cell, then cell code was modified!

# print('Hello, world')

# or, create function
def hello_test():
    print('Hello, test!')

hello_test()





%%time
import random
for i in range(0, 1000000):
    random.random()

# display time to generate 1,000,000 random numbers
# Note: Placing these comments above code generates an error!





# example
my_var1 = 1
my_var2 = 'hello'
my_var3 = True


# List all variables
%who


# List specific variable
%who bool





# example (note: includes length of string)
%pinfo my_var2





# example: list environmental variables
%env


# add new environmental variable called MY_VAR:
# %env MY_VAR=Users/someuser


# check specific environment variable value
%env JAVA_HOME
